  "key_events": {
    "2013": "Aegis Group plcを約4000-5000億円で買収（海外事業拡大の起点）",
    "2016": "決算期を3月末→12月末に変更。会計基準もIFRSへ移行",
    "2019": "コロナ禍前から広告市況悪化の兆候、のれん減損リスク顕在化",
    "2020": "大型のれん減損1421億円計上（Aegis買収時のれんが主因）+ コロナ禍で収益-10.4%。最終赤字1595億円（過去最大）",
    "2021": "V字回復。構造改革効果+コロナ後市場回復で純利益1084億円",
    "2023": "中国・豪州で追加のれん減損722億円（P&L計上）→純損失107億円",
    "2024": "のれん・無形資産減損2,353億円計上（海外が主因）→営業損失1,250億円・純損失1,922億円。ただし調整後営業利益1,762億円（OPM14.8%、前年+30bps）と実業は改善。2025年2月に中期経営計画「better」を発表（2025-2027年、OPM18%目標）。FCFは前年-710億→+291億に回復。R&I格付AA-確認。"
  },
  "_icr_note": "FY2016/2017はJ-GAAP支払利息（リース等が計上対象外）のためIFRS比較不可。FY2019/2020/2024は営業損失のためICR計算不能。FY2023の1.2倍は要注意水準だったが翌年損失転落。",
  "_cf_note": "FY2020/2021の投資CFプラスは子会社売却益（Merkle等）による。FY2023は初めてFCFがマイナス転落。FY2024はFCF+291億に回復（投資CF縮小が主因）",
  "_impairment_note": "FY2023の722億はCF計算書ベース（P&L開示531億と差異あり。差異はその他資産減損を含む可能性）。FY2024の2,353億は調整後OP(1,762億)と報告OP(-1,250億)の乖離から確認。",
  "_stock_note": "FY2024株価(3,200円)・NetDebt(4,800億)は⚠️推定値。有報よりBV/株=2,684.57円、株式報酬付与時公正価値=2,876円を参考に推算。",
  "_notation": "決算期: 2014年3月期・2015年3月期はJ-GAAP（3月末決算）。2016年12月期以降はIFRS（12月末決算）"
}
